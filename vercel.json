{
  "rewrites": [
    { "source": "/api/chat", "destination": "/api/chat.js" },
    { "source": "/api/chat-stream", "destination": "/api/chat-stream.js" },
    { "source": "/api/self-modify", "destination": "/api/self-modify.js" },
    { "source": "/api/auth/init", "destination": "/api/auth/init.js" },
    { "source": "/api/auth/callback", "destination": "/api/auth/callback.js" },
    { "source": "/api/auth/status", "destination": "/api/auth/status.js" },
    { "source": "/api/auth/gmail", "destination": "/api/auth/gmail.js" },
    { "source": "/api/gmail/send", "destination": "/api/gmail/send.js" },
    { "source": "/api/calendar/list", "destination": "/api/calendar/list.js" },
    { "source": "/api/calendar/create", "destination": "/api/calendar/create.js" },
    { "source": "/api/calendar/update", "destination": "/api/calendar/update.js" },
    { "source": "/api/calendar/delete", "destination": "/api/calendar/delete.js" },
    { "source": "/api/calendar/webhook", "destination": "/api/calendar/webhook.js" },
    { "source": "/api/calendar/watch-register", "destination": "/api/calendar/watch-register.js" },
    { "source": "/api/calendar/watch-status", "destination": "/api/calendar/watch-status.js" },
    { "source": "/api/cron/renew-calendar-watch", "destination": "/api/cron/renew-calendar-watch.js" },
    { "source": "/api/cron/poll-inquiries", "destination": "/api/cron/poll-inquiries.js" },
    { "source": "/api/deposits/list", "destination": "/api/deposits/list.js" },
    { "source": "/api/deposits/save", "destination": "/api/deposits/save.js" },
    { "source": "/api/inquiries/by-email", "destination": "/api/inquiries/by-email.js" },
    { "source": "/api/pipeline/alerts", "destination": "/api/pipeline/alerts.js" },
    { "source": "/api/pipeline/customer-history", "destination": "/api/pipeline/customer-history.js" },
    { "source": "/api/inquiries/save", "destination": "/api/inquiries/save.js" },
    { "source": "/api/chat/history", "destination": "/api/chat/history.js" },
    { "source": "/api/chat/approval", "destination": "/api/chat/approval.js" },
    { "source": "/api/notifications/subscribe", "destination": "/api/notifications/subscribe.js" },
    { "source": "/api/notifications/send", "destination": "/api/notifications/send.js" },
    { "source": "/api/notifications/vapid-key", "destination": "/api/notifications/vapid-key.js" },
    { "source": "/api/flags",      "destination": "/api/flags.js" },
    { "source": "/api/flags/:name", "destination": "/api/flags.js" },
    { "source": "/api/ai/regenerate", "destination": "/api/ai/regenerate.js" },
    { "source": "/api/ai/add-details", "destination": "/api/ai/add-details.js" },
    { "source": "/api/ai/quote-update-scan", "destination": "/api/ai/quote-update-scan.js" },
    { "source": "/api/ai/quote-updates", "destination": "/api/ai/quote-updates.js" },
    { "source": "/api/ai/thank-you-draft", "destination": "/api/ai/thank-you-draft.js" },
    { "source": "/api/cron/post-event-archive", "destination": "/api/cron/post-event-archive.js" },
    { "source": "/api/settings/guest-count-lockin", "destination": "/api/settings/guest-count-lockin.js" },
    { "source": "/api/events/today", "destination": "/api/events/today.js" },
    { "source": "/api/inquiries/completed", "destination": "/api/inquiries/completed.js" },
    { "source": "/api/cron/mark-completed",  "destination": "/api/cron/mark-completed.js" },
    { "source": "/api/customer/profile",     "destination": "/api/customer/profile.js" }
  ],
  "crons": [
    {
      "path": "/api/cron/renew-calendar-watch",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/poll-inquiries",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/post-event-archive",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/mark-completed",
      "schedule": "0 12 * * *"
    }
  ]
}
