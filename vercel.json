{
  "rewrites": [
    {
      "source": "/api/chat",
      "destination": "/api/chat.js"
    },
    {
      "source": "/api/chat-stream",
      "destination": "/api/chat-stream.js"
    },
    {
      "source": "/api/self-modify",
      "destination": "/api/self-modify.js"
    },
    {
      "source": "/api/auth/init",
      "destination": "/api/auth/init.js"
    },
    {
      "source": "/api/auth/callback",
      "destination": "/api/auth/callback.js"
    },
    {
      "source": "/api/auth/status",
      "destination": "/api/auth/status.js"
    },
    {
      "source": "/api/auth/gmail",
      "destination": "/api/auth/gmail.js"
    },
    {
      "source": "/api/gmail/send",
      "destination": "/api/gmail/send.js"
    },
    {
      "source": "/api/gmail/list-inquiries",
      "destination": "/api/gmail/list-inquiries.js"
    },
    {
      "source": "/api/gmail/extract-inquiry",
      "destination": "/api/gmail/extract-inquiry.js"
    }
  ],
  "functions": {
    "api/chat-stream.js": {
      "maxDuration": 300
    },
    "api/gmail/list-inquiries.js": {
      "maxDuration": 60
    },
    "api/gmail/extract-inquiry.js": {
      "maxDuration": 60
    }
  }
}
